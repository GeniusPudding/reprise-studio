# --- Data: heavy / private ---
# Raw WAV masters, moodboards, WhisperX drafts — regeneratable, keep out.
data/raw/**
!data/raw/.gitkeep

# Rendered MP4s live here — don't push multi-GB output to git.
out/
*.mp4

# Per-song audio shipped to /public is kept small in git (mp3); WAV should not be.
public/audio/*.wav

